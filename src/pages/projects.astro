---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../content/projects';
---

<Layout
  title="作品一覧"
  description="ゲーム作品とその他のプロジェクト集。"
  pathname="/projects"
>
  <div class="container">
    <section class="hero" style="padding-bottom: 10px;" data-reveal>
      <div class="kicker">WORKS</div>
      <h1 class="h1" style="margin-bottom: 6px;">作品一覧</h1>
      <p class="lead">ゲーム作品とその他の開発プロジェクトを紹介します。</p>
    </section>

    <section class="section" data-reveal>
      <div class="grid">
        {projects.map((p) => (
          <div class={p.isGame ? "col12" : "col6"}>
            <ProjectCard project={p} />
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>


