---
import type { Project } from '../content/projects';

type Props = {
  project: Project;
};

const { project } = Astro.props;
const isGame = project.isGame;
---

<article class:list={["card", { "gameCard": isGame }]} id={project.slug}>
  {isGame && project.image && (
    <div class="gameImageWrapper">
      <img src={project.image} alt={project.name} class="gameImage" loading="lazy" />
      <div class="gameImageOverlay"></div>
    </div>
  )}
  <div class="kicker">{project.role}</div>
  <h3 class:list={["cardTitle", { "gameTitle": isGame }]}>
    {project.name}
  </h3>
  <p class="muted cardSummary">
    {project.summary}
  </p>

  {isGame && project.highlights && (
    <ul class="gameHighlights">
      {project.highlights.slice(0, 4).map((h) => (
        <li>{h}</li>
      ))}
    </ul>
  )}

  <div class="badgeRow" aria-label="Tech stack">
    {project.stack.slice(0, 6).map((t) => (
      <span class:list={["badge", { "badgeGame": isGame }]}>{t}</span>
    ))}
  </div>

  <div class="ctaRow" style="margin-top: 12px;">
    {project.links.map((l) => (
      <a class:list={["btn", { "btnOrange": isGame && l.label === 'Steam' }]} href={l.href} {...(l.href.startsWith('http') ? { target: '_blank', rel: 'noreferrer' } : {})}>
        {l.label === 'Steam' && (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z"/>
          </svg>
        )}
        {l.label}
      </a>
    ))}
  </div>
</article>

<style>
  .cardTitle {
    margin: 6px 0 6px;
    font-size: 18px;
    letter-spacing: -0.01em;
  }
  
  .cardSummary {
    margin: 0;
  }
  
  .gameCard {
    border-color: var(--accent2) !important;
    box-shadow: 0 0 20px var(--accent2-glow), inset 0 0 30px rgba(255, 107, 53, 0.03) !important;
    overflow: hidden;
  }
  
  .gameCard::before {
    background: linear-gradient(90deg, transparent, var(--accent2), transparent) !important;
  }
  
  .gameCard:hover {
    border-color: var(--accent2) !important;
    box-shadow: 0 0 40px var(--accent2-glow), inset 0 0 50px rgba(255, 107, 53, 0.05) !important;
  }
  
  .gameImageWrapper {
    position: relative;
    margin: -16px -16px 16px -16px;
    overflow: hidden;
  }
  
  .gameImage {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }
  
  .gameImageOverlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(transparent, var(--bg));
  }
  
  .gameTitle {
    font-family: var(--font-game) !important;
    font-size: 16px !important;
    color: var(--accent2) !important;
    text-shadow: 0 0 15px var(--accent2-glow);
    letter-spacing: 0.05em !important;
  }
  
  .gameHighlights {
    margin: 12px 0;
    padding-left: 0;
    list-style: none;
    font-family: var(--font-retro);
    font-size: 16px;
    color: var(--muted);
  }
  
  .gameHighlights li {
    padding: 4px 0;
    padding-left: 20px;
    position: relative;
  }
  
  .gameHighlights li::before {
    content: '►';
    position: absolute;
    left: 0;
    color: var(--accent2);
    font-size: 10px;
    top: 50%;
    transform: translateY(-50%);
  }
  
  .badgeGame {
    border-color: var(--accent2) !important;
    background: rgba(255, 107, 53, 0.1) !important;
    color: var(--accent2) !important;
  }
</style>


