---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { profile } from '../content/profile';
import { featuredProjects } from '../content/projects';
---

<Layout
  title="Home"
  description={profile.summary}
  pathname="/"
>
  <div class="container">
    <section class="hero" data-reveal>
      <div class="kicker">{profile.location}</div>
      <h1 class="h1">
        {profile.name}
        <span class="muted" style="display:block; font-size: 0.5em; line-height: 1.2; margin-top: 10px;">
          {profile.title}
        </span>
      </h1>
      <p class="lead">{profile.summary}</p>

      <div class="ctaRow">
        <a class="btn btnPrimary" href="/projects">作品一覧を見る</a>
        <a class="btn" href="/contact">Contact</a>
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="sectionHeader">
        <h2 class="h2">作品一覧</h2>
        <a class="navLink" href="/projects">See all</a>
      </div>
      <div class="grid">
        {featuredProjects.map((p) => (
          <div class={p.isGame ? "col12" : "col6"}>
            <ProjectCard project={p} />
          </div>
        ))}
      </div>
    </section>

    <section class="section" data-reveal>
      <div class="sectionHeader">
        <h2 class="h2">Skills</h2>
      </div>
      <div class="grid">
        <div class="col6">
          <div class="card">
            <div class="kicker">Primary</div>
            <div class="badgeRow">
              {profile.skills.primary.map((s) => (
                <span class="badge">{s}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="col6">
          <div class="card">
            <div class="kicker">Tools</div>
            <div class="badgeRow">
              {profile.skills.tools.map((s) => (
                <span class="badge">{s}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
